
{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=AITestCaseGeneratorDB;User=root;Password=root;"
  },

  "Jwt": {
    "Issuer": "AITestCaseGenerator",
    "Audience": "AITestCaseGeneratorUsers",
    "SecretKey": "ThisIsASecretKeyAtLeast32CharactersLong123",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },

"LegacyCloudProviders": {
  "OpenAI": {
    "Enabled": false,
    "ApiKey": "",
    "EmbeddingModel": ""
  },
  "Gemini": {
    "Enabled": false,
    "ApiKey": "",
    "Endpoint": "",
    "Model": ""
  },
  "Anthropic": {
    "Enabled": false,
    "ApiKey": "",
    "Model": "",
    "MaxTokens": 4096,
    "Temperature": 0.2
  },
  "Claude": {
    "Enabled": false,
    "ApiKey": "",
    "Model": ""
  }
},

"Ollama": {
  "Enabled": true,
  "BaseUrl": "http://localhost:11434",
  "ChatModel": "qwen2.5:3b",
  "EmbeddingModel": "nomic-embed-text"
},

  "Embeddings": {
    "Provider": "Ollama",
    "ApiKey": "",
    "Model": "nomic-embed-text"
  },

  "ChromaDB": {
    "BaseUrl": "http://localhost:8000",
    "CollectionName": "ai-testcase-generator"
  },

  "FileStorage": {
    "UploadPath": "Uploads",
    "AllowedExtensions": [
      ".pdf",
      ".docx",
      ".txt"
    ],
    "MaxFileSizeMB": 20
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },

  "Application": {
    "Name": "AI Test Case Generator & QA Assistant",
    "Version": "1.0.0",
    "Environment": "Development"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}