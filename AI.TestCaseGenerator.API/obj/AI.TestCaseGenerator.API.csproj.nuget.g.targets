    <Import Project="$(NuGetPackageRoot)openai\2.12.0\buildTransitive\netstandard2.0\OpenAI.targets" Condition="Exists('$(NuGetPackageRoot)openai\2.12.0\buildTransitive\netstandard2.0\OpenAI.targets')" />
    <Import Project="$(NuGetPackageRoot)microsoft.aspnetcore.openapi\10.0.9\build\Microsoft.AspNetCore.OpenApi.targets" Condition="Exists('$(NuGetPackageRoot)microsoft.aspnetcore.openapi\10.0.9\build\Microsoft.AspNetCore.OpenApi.targets')" />
